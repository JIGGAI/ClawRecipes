{
  "name": "@jiggai/recipes",
  "version": "0.4.72",
  "description": "ClawRecipes plugin for OpenClaw (markdown recipes -> scaffold agents/teams)",
  "main": "dist/index.js",
  "type": "commonjs",
  "openclaw": {
    "extensions": [
      "./index.ts"
    ],
    "compat": {
      "pluginApi": ">=1.0.0",
      "pluginApiRange": ">=2026.5"
    },
    "build": {
      "openclawVersion": "2026.4.20"
    },
    "runtimeExtensions": [
      "./dist/index.js"
    ]
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist/",
    "index.ts",
    "src/",
    "openclaw.plugin.json",
    "recipes/",
    "docs/",
    "clawcipes_cook.jpg",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "test": "vitest run",
    "check:bundled-team-recipes": "node scripts/check-bundled-team-recipes.mjs",
    "test:smoke": "node scripts/scaffold-smoke.mjs",
    "test:provenance-smoke": "node scripts/scaffold-team-provenance-smoke.mjs",
    "test:agent-recipefile-smoke": "node scripts/scaffold-agent-recipefile-smoke.mjs",
    "smoke": "node scripts/scaffold-smoke.mjs",
    "scaffold:smoke": "node scripts/scaffold-smoke.mjs",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/ index.ts",
    "lint:fix": "eslint src/ index.ts --fix",
    "smell-check": "node scripts/smell-check.mjs",
    "jscpd": "jscpd src/ index.ts --min-lines 8 --min-tokens 50",
    "prepare": "husky || true",
    "check:plugin-version": "node scripts/check-openclaw-plugin-version.mjs",
    "prepack": "npm run -s build:plugin && npm run -s sync:plugin-version && npm run -s check:plugin-version",
    "prepublishOnly": "npm run -s build:plugin && npm run -s sync:plugin-version && npm run -s check:plugin-version",
    "sync:plugin-version": "node scripts/sync-openclaw-plugin-version.mjs",
    "build:plugin": "esbuild index.ts --bundle --platform=node --format=cjs --target=node20 --outfile=dist/index.js --external:openclaw/plugin-sdk",
    "verify:runtime-package": "node scripts/verify-runtime-package.mjs"
  },
  "keywords": [
    "openclaw",
    "clawrecipes",
    "plugin",
    "recipes"
  ],
  "author": "",
  "license": "Apache-2.0",
  "dependencies": {
    "@sinclair/typebox": "^0.34.48",
    "json5": "^2.2.3",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.16.0",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.16.0",
    "husky": "^9.1.7",
    "jscpd": "^4.0.5",
    "lint-staged": "^16.2.7",
    "typescript-eslint": "^8.18.0",
    "vitest": "^3.2.4",
    "esbuild": "^0.27.3"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix"
    ]
  },
  "overrides": {
    "rollup": "^4.59.0",
    "minimatch": "^10.2.4",
    "ajv": "6.14.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/JIGGAI/ClawRecipes.git"
  }
}
